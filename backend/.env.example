# Server
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/dot-jordan

# Authentication
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Frontend origin allowed by CORS
CLIENT_ORIGIN=http://localhost:3000

# Public backend URL used for file links
PUBLIC_API_URL=https://dot-backend.onrender.com

# Optional persistent upload directory (set this to a Render disk path if not using Cloudinary)
UPLOAD_DIR=

# Optional Cloudinary storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
